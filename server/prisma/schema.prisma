generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  ADMIN
  VIEWER
}

enum Priority {
  P0
  P1
  P2
  P3
}

enum Horizon {
  NOW
  NEXT
  LATER
}

enum InitiativeStatus {
  IDEA
  PLANNED
  IN_PROGRESS
  DONE
  BLOCKED
}

enum FeatureStatus {
  IDEA
  PLANNED
  IN_PROGRESS
  DONE
}

enum CommercialType {
  CONTRACT_ENABLER
  CHURN_PREVENTER
  UPSELL_DRIVER
  COMPLIANCE_GATE
  CARE_QUALITY
  COST_REDUCER
}

enum RiskLevel {
  LOW
  MEDIUM
  HIGH
}

enum AccountType {
  B2B2C
  B2G2C
  INSURER
  EMPLOYER
  PUBLIC
}

enum DemandSourceType {
  ACCOUNT
  PARTNER
  INTERNAL
  COMPLIANCE
}

enum DemandStatus {
  NEW
  VALIDATING
  APPROVED
  PLANNED
  SHIPPED
  REJECTED
}

enum AssignmentRole {
  ACCOUNTABLE
  IMPLEMENTER
  CONSULTED
  INFORMED
}

enum DateConfidence {
  LOW
  MEDIUM
  HIGH
}

enum DealStage {
  DISCOVERY
  PILOT
  CONTRACTING
  ACTIVE
  RENEWAL
}

enum StrategicTier {
  TIER_1
  TIER_2
  TIER_3
}

enum CampaignStatus {
  DRAFT
  ACTIVE
  PAUSED
  COMPLETED
  ARCHIVED
}

enum CampaignType {
  PARTNER_COBRANDING
  PRODUCT_LAUNCH
  SEASONAL
  EVENT
  WEBINAR
  REFERRAL
}

enum AssetType {
  LANDING_PAGE
  LEAFLET
  EMAIL_TEMPLATE
  BANNER
  VIDEO
  PRESENTATION
  SOCIAL_POST
}

enum AssetStatus {
  DRAFT
  IN_REVIEW
  APPROVED
  PUBLISHED
  ARCHIVED
}

model User {
  id               String       @id @default(cuid())
  email            String       @unique
  name             String
  avatarUrl        String?
  role             UserRole     @default(VIEWER)
  googleId         String?      @unique
  initiatives      Initiative[] @relation("InitiativeOwner")
  features         Feature[]    @relation("FeatureOwner")
  risks            Risk[]       @relation("RiskOwner")
  assignments      InitiativeAssignment[]
  accountsOwned    Account[]    @relation("AccountOwner")
  partnersOwned    Partner[]    @relation("PartnerOwner")
  demandsOwned     Demand[]     @relation("DemandOwner")
  campaignsOwned   Campaign[]   @relation("CampaignOwner")
  createdAt        DateTime     @default(now())
  updatedAt        DateTime     @updatedAt
}

model Product {
  id          String       @id @default(cuid())
  name        String       @unique
  description String?
  sortOrder   Int          @default(0)
  initiatives Initiative[]
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
}

model Domain {
  id          String       @id @default(cuid())
  name        String       @unique
  color       String
  sortOrder   Int
  initiatives Initiative[]
}

model Persona {
  id      String                    @id @default(cuid())
  name    String                    @unique
  icon    String?
  impacts InitiativePersonaImpact[]
  assets  Asset[]
}

model RevenueStream {
  id      String                    @id @default(cuid())
  name    String                    @unique
  color   String
  weights InitiativeRevenueStream[]
}

model Initiative {
  id             String                    @id @default(cuid())
  productId      String?
  title          String
  description    String?
  domainId       String
  ownerId        String?
  priority       Priority
  horizon        Horizon
  status         InitiativeStatus
  commercialType CommercialType
  isGap          Boolean                   @default(false)
  targetDate     DateTime?
  startDate      DateTime?
  milestoneDate  DateTime?
  dateConfidence DateConfidence?
  arrImpact      Float?
  renewalDate    DateTime?
  dealStage      DealStage?
  strategicTier  StrategicTier?
  notes          String?
  sortOrder      Int                       @default(0)
  product        Product?                  @relation(fields: [productId], references: [id], onDelete: SetNull)
  domain         Domain                    @relation(fields: [domainId], references: [id], onDelete: Cascade)
  owner          User?                     @relation("InitiativeOwner", fields: [ownerId], references: [id], onDelete: SetNull)
  personaImpacts InitiativePersonaImpact[]
  revenueWeights InitiativeRevenueStream[]
  features       Feature[]
  decisions      Decision[]
  risks          Risk[]
  demandLinks    DemandLink[]
  campaignLinks  CampaignLink[]
  assignments    InitiativeAssignment[]
  outgoingDeps   Dependency[]              @relation("FromInitiative")
  incomingDeps   Dependency[]              @relation("ToInitiative")
  createdAt      DateTime                  @default(now())
  updatedAt      DateTime                  @updatedAt
}

model InitiativePersonaImpact {
  initiativeId String
  personaId    String
  impact       Int
  initiative   Initiative @relation(fields: [initiativeId], references: [id], onDelete: Cascade)
  persona      Persona    @relation(fields: [personaId], references: [id], onDelete: Cascade)

  @@id([initiativeId, personaId])
}

model InitiativeRevenueStream {
  initiativeId   String
  revenueStreamId String
  weight         Int
  initiative     Initiative    @relation(fields: [initiativeId], references: [id], onDelete: Cascade)
  revenueStream  RevenueStream @relation(fields: [revenueStreamId], references: [id], onDelete: Cascade)

  @@id([initiativeId, revenueStreamId])
}

model Feature {
  id           String       @id @default(cuid())
  title        String
  description  String?
  initiativeId String
  ownerId      String?
  status       FeatureStatus @default(IDEA)
  startDate      DateTime?
  targetDate     DateTime?
  milestoneDate  DateTime?
  dateConfidence DateConfidence?
  sortOrder    Int          @default(0)
  initiative   Initiative   @relation(fields: [initiativeId], references: [id], onDelete: Cascade)
  owner        User?        @relation("FeatureOwner", fields: [ownerId], references: [id], onDelete: SetNull)
  requirements  Requirement[]
  demandLinks   DemandLink[]
  campaignLinks CampaignLink[]
  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt
}

model Requirement {
  id          String   @id @default(cuid())
  featureId   String
  title       String
  description String?
  isDone      Boolean  @default(false)
  priority    Priority @default(P2)
  feature     Feature  @relation(fields: [featureId], references: [id], onDelete: Cascade)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Decision {
  id           String     @id @default(cuid())
  title        String
  rationale    String?
  impactedTeams String?
  initiativeId String
  decidedAt    DateTime?
  initiative   Initiative @relation(fields: [initiativeId], references: [id], onDelete: Cascade)
  createdAt    DateTime   @default(now())
}

model Risk {
  id           String     @id @default(cuid())
  title        String
  probability  RiskLevel
  impact       RiskLevel
  mitigation   String?
  ownerId      String?
  initiativeId String
  owner        User?      @relation("RiskOwner", fields: [ownerId], references: [id], onDelete: SetNull)
  initiative   Initiative @relation(fields: [initiativeId], references: [id], onDelete: Cascade)
  createdAt    DateTime   @default(now())
}

model Dependency {
  fromInitiativeId String
  toInitiativeId   String
  description      String?
  fromInitiative   Initiative @relation("FromInitiative", fields: [fromInitiativeId], references: [id], onDelete: Cascade)
  toInitiative     Initiative @relation("ToInitiative", fields: [toInitiativeId], references: [id], onDelete: Cascade)

  @@id([fromInitiativeId, toInitiativeId])
}

model Account {
  id            String        @id @default(cuid())
  name          String
  type          AccountType
  segment       String?
  ownerId       String?
  arrImpact     Float?
  renewalDate   DateTime?
  dealStage     DealStage?
  strategicTier StrategicTier?
  owner         User?         @relation("AccountOwner", fields: [ownerId], references: [id], onDelete: SetNull)
  demands       Demand[]
  campaignLinks CampaignLink[]
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt
}

model Partner {
  id            String   @id @default(cuid())
  name          String
  kind          String
  ownerId       String?
  owner         User?    @relation("PartnerOwner", fields: [ownerId], references: [id], onDelete: SetNull)
  demands       Demand[]
  campaignLinks CampaignLink[]
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

model Demand {
  id            String           @id @default(cuid())
  title         String
  description   String?
  sourceType    DemandSourceType
  status        DemandStatus     @default(NEW)
  urgency       Int              @default(3)
  accountId     String?
  partnerId     String?
  ownerId       String?
  account       Account?         @relation(fields: [accountId], references: [id], onDelete: SetNull)
  partner       Partner?         @relation(fields: [partnerId], references: [id], onDelete: SetNull)
  owner         User?            @relation("DemandOwner", fields: [ownerId], references: [id], onDelete: SetNull)
  demandLinks   DemandLink[]
  createdAt     DateTime         @default(now())
  updatedAt     DateTime         @updatedAt
}

model DemandLink {
  id            String     @id @default(cuid())
  demandId      String
  initiativeId  String?
  featureId     String?
  demand        Demand      @relation(fields: [demandId], references: [id], onDelete: Cascade)
  initiative    Initiative? @relation(fields: [initiativeId], references: [id], onDelete: Cascade)
  feature       Feature?    @relation(fields: [featureId], references: [id], onDelete: Cascade)
  @@index([demandId])
  @@index([initiativeId])
  @@index([featureId])
}

model InitiativeAssignment {
  initiativeId String
  userId       String
  role         AssignmentRole
  allocation   Int?
  initiative   Initiative @relation(fields: [initiativeId], references: [id], onDelete: Cascade)
  user         User       @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([initiativeId, userId, role])
}

model Campaign {
  id          String         @id @default(cuid())
  name        String
  description String?
  type        CampaignType
  status      CampaignStatus @default(DRAFT)
  startDate   DateTime?
  endDate     DateTime?
  budget      Float?
  ownerId     String?
  owner       User?          @relation("CampaignOwner", fields: [ownerId], references: [id], onDelete: SetNull)
  assets      Asset[]
  links       CampaignLink[]
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt
}

model Asset {
  id          String      @id @default(cuid())
  campaignId  String
  name        String
  description String?
  type        AssetType
  status      AssetStatus @default(DRAFT)
  url         String?
  personaId   String?
  partnerId   String?
  accountId   String?
  campaign    Campaign    @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  persona     Persona?    @relation(fields: [personaId], references: [id], onDelete: SetNull)
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt
  @@index([campaignId])
}

model CampaignLink {
  id           String      @id @default(cuid())
  campaignId   String
  initiativeId String?
  featureId    String?
  accountId    String?
  partnerId    String?
  campaign     Campaign    @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  initiative   Initiative? @relation(fields: [initiativeId], references: [id], onDelete: Cascade)
  feature      Feature?    @relation(fields: [featureId], references: [id], onDelete: Cascade)
  account      Account?    @relation(fields: [accountId], references: [id], onDelete: Cascade)
  partner      Partner?    @relation(fields: [partnerId], references: [id], onDelete: Cascade)
  @@index([campaignId])
  @@index([initiativeId])
  @@index([accountId])
  @@index([partnerId])
}
