generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  SUPER_ADMIN
  ADMIN
  EDITOR
  MARKETING
  VIEWER
  PENDING
}

enum AuditAction {
  CREATED
  UPDATED
  DELETED
  STATUS_CHANGED
  ROLE_CHANGED
  LOGIN
}

enum NotificationScope {
  GLOBAL
  DOMAIN
  INITIATIVE
  CAMPAIGN
  FEATURE
  USER
}

enum DeliveryChannel {
  IN_APP
  EMAIL
  SLACK
  WHATSAPP
}

enum NotificationRecipientKind {
  OBJECT_OWNER
  OBJECT_ROLE
  GLOBAL_ROLE
  OBJECT_ASSIGNEE
}

enum NotificationDeliveryStatus {
  PENDING
  SENT
  FAILED
}

enum Priority {
  P0
  P1
  P2
  P3
}

enum Horizon {
  NOW
  NEXT
  LATER
}

enum InitiativeStatus {
  IDEA
  PLANNED
  IN_PROGRESS
  DONE
  BLOCKED
}

enum FeatureStatus {
  IDEA
  PLANNED
  IN_PROGRESS
  BUSINESS_APPROVAL
  DONE
}

enum StoryType {
  FUNCTIONAL
  BUG
  TECH_DEBT
  RESEARCH
}

enum TaskStatus {
  NOT_STARTED
  IN_PROGRESS
  TESTING
  DONE
}

enum TaskType {
  TASK
  SPIKE
  QA
  DESIGN
}

enum CommercialType {
  CONTRACT_ENABLER
  CHURN_PREVENTER
  UPSELL_DRIVER
  COMPLIANCE_GATE
  CARE_QUALITY
  COST_REDUCER
}

enum RiskLevel {
  LOW
  MEDIUM
  HIGH
}

enum AccountType {
  B2B2C
  B2G2C
  INSURER
  EMPLOYER
  PUBLIC
}

enum DemandSourceType {
  ACCOUNT
  PARTNER
  INTERNAL
  COMPLIANCE
}

enum DemandStatus {
  NEW
  VALIDATING
  APPROVED
  PLANNED
  SHIPPED
  REJECTED
}

enum AssignmentRole {
  ACCOUNTABLE
  IMPLEMENTER
  CONSULTED
  INFORMED
}

enum DateConfidence {
  LOW
  MEDIUM
  HIGH
}

enum DealStage {
  DISCOVERY
  PILOT
  CONTRACTING
  ACTIVE
  RENEWAL
}

enum StrategicTier {
  TIER_1
  TIER_2
  TIER_3
}

enum CampaignStatus {
  DRAFT
  ACTIVE
  PAUSED
  COMPLETED
  ARCHIVED
}

enum CampaignType {
  PARTNER_COBRANDING
  PRODUCT_LAUNCH
  SEASONAL
  EVENT
  WEBINAR
  REFERRAL
}

enum AssetType {
  LANDING_PAGE
  LEAFLET
  EMAIL_TEMPLATE
  BANNER
  VIDEO
  PRESENTATION
  SOCIAL_POST
}

enum AssetStatus {
  DRAFT
  IN_REVIEW
  APPROVED
  PUBLISHED
  ARCHIVED
}

enum MilestoneStatus {
  TODO
  IN_PROGRESS
  DONE
  BLOCKED
}

enum StakeholderRole {
  DECISION_MAKER
  SPONSOR
  REVIEWER
  AMBASSADOR
  LEGAL
  MEDICAL
}

enum StakeholderType {
  INTERNAL
  EXTERNAL
}

model User {
  id               String       @id @default(cuid())
  email            String       @unique
  name             String
  avatarUrl        String?
  role             UserRole     @default(VIEWER)
  isActive         Boolean      @default(true)
  lastLoginAt      DateTime?
  googleId         String?      @unique
  emails           UserEmail[]
  initiatives      Initiative[] @relation("InitiativeOwner")
  features         Feature[]    @relation("FeatureOwner")
  risks            Risk[]       @relation("RiskOwner")
  assignments      InitiativeAssignment[]
  accountsOwned    Account[]    @relation("AccountOwner")
  partnersOwned    Partner[]    @relation("PartnerOwner")
  demandsOwned     Demand[]     @relation("DemandOwner")
  campaignsOwned   Campaign[]   @relation("CampaignOwner")
  milestonesOwned  InitiativeMilestone[] @relation("MilestoneOwner")
  initiativeComments InitiativeComment[]
  userMessages     UserMessage[]
  auditEntries     AuditEntry[]
  notificationSubscriptions UserNotificationSubscription[]
  notificationPreferences   UserNotificationPreference[]
  requirementsAssigned Requirement[] @relation("RequirementAssignee")
  preferredLocale  String?
  createdAt        DateTime     @default(now())
  updatedAt        DateTime     @updatedAt
}

model UserMessage {
  id             String    @id @default(cuid())
  userId         String
  user           User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  title          String?
  body           String?
  linkUrl        String?
  linkLabel      String?
  titleKey       String?
  titleParams    Json?
  bodyKey        String?
  bodyParams     Json?
  linkLabelKey   String?
  linkLabelParams Json?
  entityType     String?
  entityId       String?
  auditEntryId   String?
  readAt         DateTime?
  source         String?
  type           String?
  createdAt      DateTime  @default(now())
  deliveries     NotificationDelivery[]

  @@index([userId])
  @@index([userId, readAt])
  @@unique([userId, auditEntryId])
}

model UserEmail {
  id        String   @id @default(cuid())
  email     String   @unique
  userId    String
  isPrimary Boolean  @default(false)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())

  @@index([userId])
}

model Product {
  id          String       @id @default(cuid())
  name        String       @unique
  description String?
  sortOrder   Int          @default(0)
  initiatives Initiative[]
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
}

model Domain {
  id          String       @id @default(cuid())
  name        String       @unique
  color       String
  sortOrder   Int
  initiatives Initiative[]
}

enum PersonaCategory {
  BUYER
  USER
  NONE
}

model Persona {
  id       String                    @id @default(cuid())
  name     String                    @unique
  icon     String?
  category PersonaCategory           @default(NONE)
  impacts  InitiativePersonaImpact[]
  assets   Asset[]
}

model RevenueStream {
  id      String                    @id @default(cuid())
  name    String                    @unique
  color   String
  weights InitiativeRevenueStream[]
}

model Initiative {
  id             String                    @id @default(cuid())
  productId      String?
  title          String
  description    String?
  domainId       String
  ownerId        String?
  priority       Priority
  horizon        Horizon
  status         InitiativeStatus
  commercialType CommercialType
  isGap          Boolean                   @default(false)
  targetDate     DateTime?
  startDate      DateTime?
  milestoneDate  DateTime?
  dateConfidence DateConfidence?
  arrImpact      Float?
  renewalDate    DateTime?
  dealStage      DealStage?
  strategicTier  StrategicTier?
  problemStatement String?
  successCriteria  String?
  notes            String?
  sortOrder        Int                       @default(0)
  archivedAt       DateTime?
  product          Product?                  @relation(fields: [productId], references: [id], onDelete: SetNull)
  domain           Domain                    @relation(fields: [domainId], references: [id], onDelete: Cascade)
  owner            User?                     @relation("InitiativeOwner", fields: [ownerId], references: [id], onDelete: SetNull)
  personaImpacts   InitiativePersonaImpact[]
  revenueWeights   InitiativeRevenueStream[]
  features         Feature[]
  decisions        Decision[]
  risks            Risk[]
  demandLinks      DemandLink[]
  campaignLinks    CampaignLink[]
  assignments      InitiativeAssignment[]
  milestones       InitiativeMilestone[]
  kpis             InitiativeKPI[]
  stakeholders     Stakeholder[]
  outgoingDeps     Dependency[]              @relation("FromInitiative")
  incomingDeps     Dependency[]              @relation("ToInitiative")
  comments         InitiativeComment[]
  successCriteriaItems SuccessCriterion[]
  createdAt        DateTime                  @default(now())
  updatedAt        DateTime                  @updatedAt
}

model SuccessCriterion {
  id           String     @id @default(cuid())
  initiativeId String
  title        String
  sortOrder    Int        @default(0)
  isDone       Boolean    @default(false)
  initiative   Initiative @relation(fields: [initiativeId], references: [id], onDelete: Cascade)
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt
  @@index([initiativeId])
}

model InitiativeComment {
  id           String     @id @default(cuid())
  initiativeId String
  userId       String
  text         String
  createdAt    DateTime   @default(now())
  initiative   Initiative @relation(fields: [initiativeId], references: [id], onDelete: Cascade)
  user         User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  @@index([initiativeId])
  @@index([userId])
}

model InitiativePersonaImpact {
  initiativeId String
  personaId    String
  impact       Int
  initiative   Initiative @relation(fields: [initiativeId], references: [id], onDelete: Cascade)
  persona      Persona    @relation(fields: [personaId], references: [id], onDelete: Cascade)

  @@id([initiativeId, personaId])
}

model InitiativeRevenueStream {
  initiativeId   String
  revenueStreamId String
  weight         Int
  initiative     Initiative    @relation(fields: [initiativeId], references: [id], onDelete: Cascade)
  revenueStream  RevenueStream @relation(fields: [revenueStreamId], references: [id], onDelete: Cascade)

  @@id([initiativeId, revenueStreamId])
}

model Feature {
  id                 String         @id @default(cuid())
  title              String
  description        String?
  acceptanceCriteria String?
  labels             Json?
  storyPoints        Int?
  storyType          StoryType?
  initiativeId       String
  ownerId            String?
  status             FeatureStatus  @default(IDEA)
  startDate          DateTime?
  targetDate         DateTime?
  milestoneDate      DateTime?
  dateConfidence     DateConfidence?
  sortOrder          Int            @default(0)
  initiative         Initiative     @relation(fields: [initiativeId], references: [id], onDelete: Cascade)
  owner              User?          @relation("FeatureOwner", fields: [ownerId], references: [id], onDelete: SetNull)
  requirements       Requirement[]
  demandLinks        DemandLink[]
  campaignLinks      CampaignLink[]
  createdAt          DateTime       @default(now())
  updatedAt          DateTime       @updatedAt
}

model Requirement {
  id            String     @id @default(cuid())
  featureId     String
  title         String
  description   String?
  status        TaskStatus @default(NOT_STARTED)
  isDone        Boolean    @default(false)
  priority      Priority   @default(P2)
  assigneeId    String?
  dueDate       DateTime?
  estimate      String?
  labels        Json?
  taskType      TaskType?
  blockedReason String?
  externalRef   String?
  metadata      Json?
  sortOrder     Int        @default(0)
  feature       Feature    @relation(fields: [featureId], references: [id], onDelete: Cascade)
  assignee      User?      @relation("RequirementAssignee", fields: [assigneeId], references: [id], onDelete: SetNull)
  createdAt     DateTime   @default(now())
  updatedAt     DateTime   @updatedAt

  @@index([assigneeId])
}

model Decision {
  id           String     @id @default(cuid())
  title        String
  rationale    String?
  impactedTeams String?
  initiativeId String
  decidedAt    DateTime?
  initiative   Initiative @relation(fields: [initiativeId], references: [id], onDelete: Cascade)
  createdAt    DateTime   @default(now())
}

model Risk {
  id           String     @id @default(cuid())
  title        String
  probability  RiskLevel
  impact       RiskLevel
  mitigation   String?
  ownerId      String?
  initiativeId String
  owner        User?      @relation("RiskOwner", fields: [ownerId], references: [id], onDelete: SetNull)
  initiative   Initiative @relation(fields: [initiativeId], references: [id], onDelete: Cascade)
  createdAt    DateTime   @default(now())
}

model Dependency {
  fromInitiativeId String
  toInitiativeId   String
  description      String?
  fromInitiative   Initiative @relation("FromInitiative", fields: [fromInitiativeId], references: [id], onDelete: Cascade)
  toInitiative     Initiative @relation("ToInitiative", fields: [toInitiativeId], references: [id], onDelete: Cascade)

  @@id([fromInitiativeId, toInitiativeId])
}

model Account {
  id            String        @id @default(cuid())
  name          String
  type          AccountType
  segment       String?
  ownerId       String?
  arrImpact     Float?
  renewalDate   DateTime?
  dealStage     DealStage?
  strategicTier StrategicTier?
  owner         User?         @relation("AccountOwner", fields: [ownerId], references: [id], onDelete: SetNull)
  demands       Demand[]
  campaignLinks CampaignLink[]
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt
}

model Partner {
  id            String   @id @default(cuid())
  name          String
  kind          String
  ownerId       String?
  owner         User?    @relation("PartnerOwner", fields: [ownerId], references: [id], onDelete: SetNull)
  demands       Demand[]
  campaignLinks CampaignLink[]
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

model Demand {
  id            String           @id @default(cuid())
  title         String
  description   String?
  sourceType    DemandSourceType
  status        DemandStatus     @default(NEW)
  urgency       Int              @default(3)
  accountId     String?
  partnerId     String?
  ownerId       String?
  account       Account?         @relation(fields: [accountId], references: [id], onDelete: SetNull)
  partner       Partner?         @relation(fields: [partnerId], references: [id], onDelete: SetNull)
  owner         User?            @relation("DemandOwner", fields: [ownerId], references: [id], onDelete: SetNull)
  demandLinks   DemandLink[]
  createdAt     DateTime         @default(now())
  updatedAt     DateTime         @updatedAt
}

model DemandLink {
  id            String     @id @default(cuid())
  demandId      String
  initiativeId  String?
  featureId     String?
  demand        Demand      @relation(fields: [demandId], references: [id], onDelete: Cascade)
  initiative    Initiative? @relation(fields: [initiativeId], references: [id], onDelete: Cascade)
  feature       Feature?    @relation(fields: [featureId], references: [id], onDelete: Cascade)
  @@index([demandId])
  @@index([initiativeId])
  @@index([featureId])
}

model InitiativeAssignment {
  initiativeId String
  userId       String
  role         AssignmentRole
  allocation   Int?
  initiative   Initiative @relation(fields: [initiativeId], references: [id], onDelete: Cascade)
  user         User       @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([initiativeId, userId, role])
}

model Campaign {
  id          String         @id @default(cuid())
  name        String
  description String?
  type        CampaignType
  status      CampaignStatus @default(DRAFT)
  startDate   DateTime?
  endDate     DateTime?
  budget      Float?
  ownerId     String?
  owner       User?          @relation("CampaignOwner", fields: [ownerId], references: [id], onDelete: SetNull)
  assets      Asset[]
  links       CampaignLink[]
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt
}

model Asset {
  id          String      @id @default(cuid())
  campaignId  String
  name        String
  description String?
  type        AssetType
  status      AssetStatus @default(DRAFT)
  url         String?
  personaId   String?
  partnerId   String?
  accountId   String?
  campaign    Campaign    @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  persona     Persona?    @relation(fields: [personaId], references: [id], onDelete: SetNull)
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt
  @@index([campaignId])
}

model CampaignLink {
  id           String      @id @default(cuid())
  campaignId   String
  initiativeId String?
  featureId    String?
  accountId    String?
  partnerId    String?
  campaign     Campaign    @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  initiative   Initiative? @relation(fields: [initiativeId], references: [id], onDelete: Cascade)
  feature      Feature?    @relation(fields: [featureId], references: [id], onDelete: Cascade)
  account      Account?    @relation(fields: [accountId], references: [id], onDelete: Cascade)
  partner      Partner?    @relation(fields: [partnerId], references: [id], onDelete: Cascade)
  @@index([campaignId])
  @@index([initiativeId])
  @@index([accountId])
  @@index([partnerId])
}

model InitiativeMilestone {
  id           String          @id @default(cuid())
  initiativeId String
  title        String
  description  String?
  status       MilestoneStatus @default(TODO)
  targetDate   DateTime?
  ownerId      String?
  sequence     Int             @default(0)
  initiative   Initiative      @relation(fields: [initiativeId], references: [id], onDelete: Cascade)
  owner        User?           @relation("MilestoneOwner", fields: [ownerId], references: [id], onDelete: SetNull)
  createdAt    DateTime        @default(now())
  updatedAt    DateTime        @updatedAt

  @@index([initiativeId])
}

model InitiativeKPI {
  id           String     @id @default(cuid())
  initiativeId String
  title        String
  targetValue  String?
  currentValue String?
  unit         String?
  targetDate   DateTime?
  initiative   Initiative @relation(fields: [initiativeId], references: [id], onDelete: Cascade)
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt

  @@index([initiativeId])
}

model Stakeholder {
  id           String          @id @default(cuid())
  initiativeId String
  name         String
  role         StakeholderRole
  type         StakeholderType
  organization String?
  initiative   Initiative      @relation(fields: [initiativeId], references: [id], onDelete: Cascade)
  createdAt    DateTime        @default(now())

  @@index([initiativeId])
}

model AuditEntry {
  id         String      @id @default(cuid())
  userId     String
  action     AuditAction
  entityType String
  entityId   String?
  details    Json?
  user       User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt  DateTime    @default(now())
  @@index([userId])
  @@index([entityType, entityId])
  @@index([createdAt])
}

model NotificationRule {
  id               String                   @id @default(cuid())
  action           AuditAction
  entityType       String
  eventKind        String?
  recipientKind   NotificationRecipientKind
  recipientRole   String?
  deliveryChannels Json                     // array of DeliveryChannel names, default ["IN_APP"]
  enabled          Boolean                  @default(true)
  createdAt        DateTime                 @default(now())
  updatedAt        DateTime                 @updatedAt

  @@index([action, entityType, enabled])
}

model UserNotificationSubscription {
  id               String            @id @default(cuid())
  userId           String
  user             User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  action           AuditAction
  entityType       String
  scopeType        NotificationScope
  scopeId          String?
  deliveryChannels Json              // array of DeliveryChannel names, default ["IN_APP"]
  createdAt        DateTime         @default(now())

  @@unique([userId, action, entityType, scopeType, scopeId])
  @@index([userId])
}

model UserNotificationPreference {
  id                 String         @id @default(cuid())
  userId             String
  user               User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  channel            DeliveryChannel
  enabled            Boolean        @default(true)
  channelIdentifier  String?        // email, Slack user id, phone - no validation yet
  createdAt          DateTime       @default(now())
  updatedAt          DateTime       @updatedAt

  @@unique([userId, channel])
  @@index([userId])
}

model NotificationDelivery {
  id             String                     @id @default(cuid())
  userMessageId  String?
  userMessage    UserMessage?               @relation(fields: [userMessageId], references: [id], onDelete: Cascade)
  userId         String
  channel        DeliveryChannel
  status         NotificationDeliveryStatus
  sentAt         DateTime?
  externalId     String?
  createdAt      DateTime                   @default(now())

  @@index([userMessageId])
  @@index([userId])
}

model McpOAuthClient {
  id        String   @id @default(cuid())
  clientId  String   @unique
  payload   Json     // OAuthClientInformationFull (client_id, redirect_uris, client_name, etc.)
  createdAt DateTime @default(now())

  @@index([clientId])
}

enum CapabilityStatus {
  ACTIVE
  DRAFT
  DEPRECATED
}

enum BindingType {
  ROUTE
  PAGE
  API_ROUTE
  MCP_TOOL
  PRISMA_MODEL
  FILE_GLOB
  INFRA
  /// Figma file/node identifier (see docs/DESIGN_REFERENCES.md)
  FIGMA_NODE
  /// Tool-agnostic design URL or stable id (Figma, Penpot, brief doc, …)
  DESIGN_REF
}

/// Product capability in user language; binds to routes, MCP tools, models, etc.
model Capability {
  id               String            @id @default(cuid())
  slug             String            @unique
  title            String
  description      String?
  userJob          String?
  synonyms         Json?
  doNotConfuseWith String?
  status           CapabilityStatus  @default(DRAFT)
  parentId         String?
  parent           Capability?       @relation("CapabilityHierarchy", fields: [parentId], references: [id], onDelete: SetNull)
  children         Capability[]      @relation("CapabilityHierarchy")
  bindings         CapabilityBinding[]
  sortOrder        Int               @default(0)
  createdAt        DateTime          @default(now())
  updatedAt        DateTime          @updatedAt

  @@index([parentId])
  @@index([status])
}

model CapabilityBinding {
  id           String      @id @default(cuid())
  capabilityId String
  capability   Capability  @relation(fields: [capabilityId], references: [id], onDelete: Cascade)
  bindingType  BindingType
  bindingKey   String
  notes        String?
  isPrimary    Boolean     @default(false)
  generated    Boolean     @default(false)
  createdAt    DateTime    @default(now())
  updatedAt    DateTime    @updatedAt

  @@unique([capabilityId, bindingType, bindingKey])
  @@index([capabilityId])
  @@index([bindingType, bindingKey])
}

/// Latest compiled agent brief per format + mode (upsert on compile).
model CompiledBrief {
  id          String   @id @default(cuid())
  format      String
  mode        String
  contentHash String
  content     String   @db.Text
  generatedAt DateTime @default(now())

  @@unique([format, mode])
}

/// Singleton row: which main nav routes are hidden for non–super-admin users.
model UiSettings {
  id               String   @id @default("default")
  hiddenNavPaths   Json     @default("[]")
  updatedAt        DateTime @updatedAt
}
