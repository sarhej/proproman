{
  "mcpServers": {
    "tymio-local": {
      "url": "http://localhost:8080/mcp"
    },
    "tymio-remote": {
      "url": "https://tymio.app/mcp"
    },
    "tymio-stdio": {
      "type": "stdio",
      "command": "node",
      "args": ["${workspaceFolder}/mcp/dist/index.js"],
      "env": {
        "DRD_API_BASE_URL": "http://localhost:8080"
      },
      "envFile": "${workspaceFolder}/server/.env"
    }
  }
}
