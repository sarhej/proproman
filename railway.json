{
  "$schema": "https://railway.app/railway.schema.json",
  "build": {
    "builder": "DOCKERFILE",
    "dockerfilePath": "Dockerfile",
    "watchPatterns": ["/server/**", "/client/**", "/Dockerfile", "/package.json"]
  },
  "deploy": {
    "preDeployCommand": "node server/scripts/pre-deploy.cjs",
    "restartPolicyType": "ON_FAILURE",
    "restartPolicyMaxRetries": 10
  }
}
